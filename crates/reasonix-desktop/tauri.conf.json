{
  "$schema": "https://raw.githubusercontent.com/nicegram/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "DPronix",
  "version": "0.1.0",
  "identifier": "com.dpronix.desktop",
  "build": {
    "beforeDevCommand": "cd frontend && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd frontend && npm run build",
    "frontendDist": "./frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "DPronix — AI Coding Agent",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "hiddenTitle": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
